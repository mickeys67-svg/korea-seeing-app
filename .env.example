# Clear Skies App - Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=8080
NODE_ENV=development

# MongoDB (optional — app works without it)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/clearsky

# CORS (comma-separated origins, defaults to clearsky.kr + localhost)
# CORS_ORIGINS=https://www.clearsky.kr,https://clearsky.kr,http://localhost:5173

# Met.no contact email (required by their API policy)
# CONTACT_EMAIL=support@clearsky.kr

# KMA 기상청 초단기예보 API (한국 좌표 전용, data.go.kr 발급)
# KMA_API_KEY=your_service_key_here

# KMA 고층관측(라디오존데) API (한국 전용, apihub.kma.go.kr 발급)
# KMA_UPP_API_KEY=your_apihub_auth_key_here

# Cloud Ensemble + METAR (no API key needed, $0 cost)
# Open-Meteo Ensemble: https://ensemble-api.open-meteo.com (auto-enabled)
# AviationWeather METAR: https://aviationweather.gov/api/data/metar (auto-enabled)

# AI Analysis: rule-based engine (no API key needed, $0 cost)
