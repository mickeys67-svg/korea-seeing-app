# Clear Skies App - Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=8080
NODE_ENV=development

# MongoDB (optional — app works without it)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/clearsky

# CORS (comma-separated origins, defaults to clearsky.kr + localhost)
# CORS_ORIGINS=https://www.clearsky.kr,https://clearsky.kr,http://localhost:5173

# Met.no contact email (required by their API policy)
# CONTACT_EMAIL=support@clearsky.kr

# AI Analysis: rule-based engine (no API key needed, $0 cost)
